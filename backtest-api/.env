# Copy this file to .env and fill in your values.
# DATABASE_URL is required — the app will not start without it.
DATABASE_URL=postgresql://aryamangoenka@localhost:5432/mig_backtest

# Directory where uploaded strategy files are stored
UPLOAD_DIR=uploads

# Directory for per-submission execution logs
LOGS_DIR=logs

# Path to the market data CSV (50 tickers, daily OHLCV)
DATA_PATH=public_test_data.csv

# Docker image name for the sandbox runner
SANDBOX_IMAGE=mig-sandbox:latest

# How long (seconds) a submission is allowed to run before being killed
SUBMISSION_TIMEOUT_SECONDS=60

# Max uploaded file size in bytes (default: 1 MB)
MAX_FILE_SIZE_BYTES=1048576

# How often the worker polls for queued submissions (seconds)
WORKER_POLL_INTERVAL_SECONDS=5
